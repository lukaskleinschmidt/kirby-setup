{
  "name": "lukaskleinschmidt/kirby-setup",
  "description": "Kirby Setup",
  "type": "project",
  "authors": [
    {
      "name": "Lukas Kleinschmidt",
      "email": "github@kleinschmidt.mozmail.com"
    }
  ],
  "require": {
    "php": "^8.5",
    "getkirby/cms": "5.4.4",
    "getkirby/cli": "1.9.0",
    "monolog/monolog": "3.10.0",
    "symfony/var-dumper": "8.1.1",
    "vlucas/phpdotenv": "5.6.3"
  },
  "autoload": {
    "files": [
      "app/helpers.php"
    ],
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "allow-plugins": {
      "getkirby/composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  },
  "extra": {
    "kirby-cms-path": false,
    "kirby-plugin-path": "site/plugins/vendor"
  }
}
